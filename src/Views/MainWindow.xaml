<Window x:Class="ClipPanda.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipPanda.ViewModels"
        Title="ClipPanda"
        Width="600" Height="500"
        MinWidth="400" MinHeight="300"
        Style="{StaticResource ModernWindowStyle}"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Deactivated="MainWindow_OnDeactivated"
        KeyDown="MainWindow_OnKeyDown">

    <Window.Resources>
        <ResourceDictionary Source="/Assets/Styles.xaml"/>
    </Window.Resources>

    <!-- 窗口容器 -->
    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 - 支持拖动 -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8,8,0,0" Padding="16,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/icon_256.png" 
                               Width="24" Height="24" 
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="ClipPanda"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconButtonStyle}"
                                Click="SettingsButton_Click"
                                ToolTip="设置"
                                Margin="0,0,8,0">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                  Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="关闭">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                  Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 搜索框 -->
            <Border Grid.Row="1" Background="White" Margin="12,12,12,0" CornerRadius="6" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                          Fill="{StaticResource TextMutedBrush}"
                          Width="18" Height="18"
                          Stretch="Uniform"
                          Margin="12,0,0,0"/>

                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Style="{StaticResource SearchTextBoxStyle}"
                             TextChanged="SearchTextBox_OnTextChanged"
                             Text=""
                             Tag="搜索剪贴板历史..."/>
                </Grid>
            </Border>

            <!-- Tab 切换栏 + 类型筛选 -->
            <Border Grid.Row="2" Margin="12,8,12,0" Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <RadioButton Content="全部"
                                     Style="{StaticResource TabButtonStyle}"
                                     IsChecked="{Binding ShowFavoritesOnly, Converter={StaticResource InvertBoolConverter}, Mode=OneWay}"
                                     GroupName="TabGroup"
                                     Click="AllTab_Click"/>
                        <RadioButton Content="收藏"
                                     Style="{StaticResource TabButtonStyle}"
                                     IsChecked="{Binding ShowFavoritesOnly, Mode=OneWay}"
                                     GroupName="TabGroup"
                                     Click="FavoritesTab_Click"/>
                    </StackPanel>
                    
                    <!-- 类型筛选下拉框 -->
                    <ComboBox Grid.Column="2"
                              Width="100"
                              Height="28"
                              ItemsSource="{Binding ContentTypeFilters}"
                              SelectedIndex="{Binding SelectedContentTypeIndex, Mode=TwoWay}"
                              VerticalContentAlignment="Center"
                              FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 列表区域 -->
            <Border Grid.Row="3" Margin="12,8,12,0" Style="{StaticResource CardStyle}">
                <Grid>
                    <!-- 空状态 -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Path Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10-4.48 10-10S17.52,2 12,2zm-2,15l-5-5 1.41-1.41L10,14.17l7.59-7.59L19,8l-9,9z"
                              Fill="{StaticResource TextMutedBrush}" 
                              Width="48" Height="48" 
                              Stretch="Uniform"
                              Opacity="0.5"/>
                        <TextBlock Text="{Binding EmptyStateTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,8"/>
                        <TextBlock Text="{Binding EmptyStateDescription}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="280"
                                   TextAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- 列表 -->
                    <ListBox x:Name="ClipboardListBox"
                             ItemsSource="{Binding ClipboardItems}"
                             SelectedItem="{Binding SelectedItem}"
                             ItemContainerStyle="{StaticResource ClipboardItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ClipboardListBox_OnMouseDoubleClick"
                             Visibility="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 类型图标或图片缩略图 -->
                                <Border Grid.Column="0"
                                        Width="32" Height="32"
                                        CornerRadius="6"
                                        Background="{Binding ContentTypeColor}"
                                        Margin="0,0,12,0"
                                        Visibility="{Binding IsImage, Converter={StaticResource InvertBoolConverter}}">
                                    <TextBlock Text="{Binding ContentTypeIcon}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Image Grid.Column="0"
                                       Width="32" Height="32"
                                       Source="{Binding ThumbnailImage}"
                                       Stretch="UniformToFill"
                                       Margin="0,0,12,0"
                                       Visibility="{Binding IsImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <!-- 内容预览 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Preview}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TimeDisplay}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- 收藏图标 -->
                                <TextBlock Grid.Column="2"
                                           Text="★"
                                           FontSize="14"
                                           Foreground="#FFB900"
                                           Visibility="{Binding FavoriteVisibility}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </Border>

            <!-- 底部状态栏 -->
            <Border Grid.Row="4" Padding="12,8" Background="Transparent">
                <Grid>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="Ctrl+Shift+C 切换 | Enter 粘贴 | Ctrl+S 收藏 | Del 删除"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
