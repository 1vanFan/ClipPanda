<Window x:Class="ClipPanda.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipPanda 设置"
        Width="480" Height="520"
        MinWidth="400" MinHeight="400"
        Style="{StaticResource ModernWindowStyle}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary Source="/Assets/Styles.xaml"/>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8,8,0,0" Padding="16,12">
                <Grid>
                    <TextBlock Text="设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Click="CloseButton_Click"
                            HorizontalAlignment="Right"
                            ToolTip="关闭">
                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                              Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 设置内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>

                    <!-- 快捷键设置 -->
                    <TextBlock Text="快捷键" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="主快捷键" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="HotkeyTextBox"
                                         Text="{Binding MainHotkey, UpdateSourceTrigger=PropertyChanged}"
                                         Width="160" Height="30"
                                         FontSize="13" Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         IsReadOnly="True"
                                         Background="White"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"/>
                            </Grid>
                            <TextBlock Text="点击输入框后按下快捷键组合来更改"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- 历史记录设置 -->
                    <TextBlock Text="历史记录" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="最大记录数" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          SelectedValue="{Binding MaxHistoryCount}"
                                          Width="120" Height="30" FontSize="13"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="100" Tag="100"/>
                                    <ComboBoxItem Content="200" Tag="200"/>
                                    <ComboBoxItem Content="500" Tag="500"/>
                                    <ComboBoxItem Content="1000" Tag="1000"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="保留天数" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          SelectedValue="{Binding HistoryRetentionDays}"
                                          Width="120" Height="30" FontSize="13"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="3 天" Tag="3"/>
                                    <ComboBoxItem Content="7 天" Tag="7"/>
                                    <ComboBoxItem Content="14 天" Tag="14"/>
                                    <ComboBoxItem Content="30 天" Tag="30"/>
                                    <ComboBoxItem Content="永久" Tag="365"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 外观设置 -->
                    <TextBlock Text="外观" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="主题配色" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource ColorRadioStyle}" 
                                                 Tag="Blue" GroupName="ThemeColor"
                                                 IsChecked="{Binding IsBlueTheme}"
                                                 Background="#2B579A"/>
                                    <RadioButton Style="{StaticResource ColorRadioStyle}" 
                                                 Tag="Green" GroupName="ThemeColor"
                                                 IsChecked="{Binding IsGreenTheme}"
                                                 Background="#107C10"/>
                                    <RadioButton Style="{StaticResource ColorRadioStyle}" 
                                                 Tag="Purple" GroupName="ThemeColor"
                                                 IsChecked="{Binding IsPurpleTheme}"
                                                 Background="#5C2D91"/>
                                    <RadioButton Style="{StaticResource ColorRadioStyle}" 
                                                 Tag="Orange" GroupName="ThemeColor"
                                                 IsChecked="{Binding IsOrangeTheme}"
                                                 Background="#D83B01"/>
                                    <RadioButton Style="{StaticResource ColorRadioStyle}" 
                                                 Tag="Pink" GroupName="ThemeColor"
                                                 IsChecked="{Binding IsPinkTheme}"
                                                 Background="#C30052"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 功能开关 -->
                    <TextBlock Text="功能" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="开机自启动" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="系统启动时自动运行 ClipPanda" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding StartWithWindows}"
                                              Content="{Binding StartWithWindows}"
                                              Width="44" Height="22"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="自动去重" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="复制相同内容时自动更新时间戳" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding EnableAutoDeduplication}"
                                              Width="44" Height="22"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="最小化到托盘" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="关闭窗口时最小化到系统托盘" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding MinimizeToTray}"
                                              Width="44" Height="22"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="复制通知" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="复制内容时显示通知提示" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding ShowCopyNotification}"
                                              Width="44" Height="22"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Padding="16,12" BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <TextBlock Text="设置更改后立即生效"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="保存设置"
                            Click="SaveButton_Click"
                            Width="100" Height="32"
                            HorizontalAlignment="Right"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Template="{StaticResource ModernButtonTemplate}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
